{
  "name": "nanostores-mcp",
  "version": "0.1.0",
  "description": "MCP server for Nano Stores: devtools, migration helpers, logger integration",
  "repository": "https://github.com/Valyay/nanostores-mcp",
  "homepage": "https://github.com/Valyay/nanostores-mcp#readme",
  "bugs": {
    "url": "https://github.com/Valyay/nanostores-mcp/issues"
  },
  "license": "MIT",
  "private": false,
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "nanostores-mcp": "dist/cli.js"
  },
  "sideEffects": false,
  "author": "Evgeniy Valyaev <dev.valyay@gmail.com>",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./cli": "./dist/cli.js",
    "./mcpLogger": {
      "types": "./dist/client/mcpLogger.d.ts",
      "import": "./dist/client/mcpLogger.js"
    }
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "lint": "eslint .",
    "lint:fix": "pnpm run lint -- --fix",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "check": "pnpm run lint && pnpm run format && pnpm run test && pnpm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "nanostores",
    "devtools",
    "logger"
  ],
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.19.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@toon-format/toon": "^2.1.0",
    "globby": "^16.0.0",
    "is-path-inside": "^4.0.0",
    "nanoid": "^5.1.6",
    "ts-morph": "^27.0.2",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "@nanostores/logger": "^1.0.0",
    "@vue/compiler-sfc": "^3.0.0",
    "nanostores": "^1.1.0",
    "svelte": "^4.0.0 || ^5.0.0"
  },
  "peerDependenciesMeta": {
    "@nanostores/logger": {
      "optional": true
    },
    "@vue/compiler-sfc": {
      "optional": true
    },
    "svelte": {
      "optional": true
    }
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@nanostores/logger": "^1.0.0",
    "@types/node": "^24.10.0",
    "@vitest/coverage-v8": "^4.0.18",
    "@vue/compiler-sfc": "^3.5.27",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "nanostores": "^1.1.0",
    "prettier": "^3.7.0",
    "svelte": "^5.49.0",
    "tsx": "^4.20.0",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.17"
  }
}
